# HIFZ Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# CLERK AUTHENTICATION (Required)
# ============================================
# Get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk URLs (optional, defaults work for most cases)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ============================================
# DEEPGRAM - Real-time Speech Recognition (Optional)
# ============================================
# Get your key from https://console.deepgram.com
# $200 free credits for new accounts!
DEEPGRAM_API_KEY=

# ============================================
# ANTHROPIC - Claude AI (Optional)
# ============================================
# Get your key from https://console.anthropic.com
# Used for detailed tajweed analysis
ANTHROPIC_API_KEY=

# ============================================
# OPENAI (Optional)
# ============================================
OPENAI_API_KEY=

# ============================================
# DATABASE — Turso/LibSQL (Optional)
# ============================================
# Get from https://turso.tech dashboard
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ============================================
# TARTEEL WHISPER - Quran-specific ASR (Optional)
# ============================================
# Server-side transcription via Modal
# Deploy with: cd /path/to/project && modal deploy modal_whisper.py
MODAL_WHISPER_URL=https://YOUR-MODAL-WORKSPACE--hifz-whisper-transcribe-api.modal.run

# Alternative: HuggingFace Inference API
HUGGINGFACE_API_KEY=

# Transcription provider: tarteel | deepgram | hybrid
TRANSCRIPTION_PROVIDER=tarteel

# Enable browser-based offline mode
ENABLE_OFFLINE_MODE=true

# ============================================
# ADMIN (Optional)
# ============================================
# Comma-separated Clerk user IDs for admin access
ADMIN_USER_IDS=
NEXT_PUBLIC_ADMIN_USER_IDS=
# Comma-separated admin emails
ADMIN_EMAILS=

# ============================================
# PREMIUM (Optional)
# ============================================
# Set to "true" to bypass premium checks in development
NEXT_PUBLIC_BYPASS_PREMIUM=

# ============================================
# PUSH NOTIFICATIONS (Optional)
# ============================================
# Generate VAPID keys: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ============================================
# SITE URL (Optional)
# ============================================
NEXT_PUBLIC_SITE_URL=https://gethifz.com

# ============================================
# ANALYTICS (Optional)
# ============================================
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
